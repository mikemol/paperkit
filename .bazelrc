common --enable_bzlmod
test --test_output=errors --test_summary=terse
# A memory-budget pool (replaces the vendored membudget semaphore — Ζ·membudget).  A check
# declares `mem` (MB) in its bib; Ζ·starlark projects that to tags = ["resources:mem_mb:N"], and
# Bazel's local scheduler bounds concurrent memory to this pool.  Native, per-machine, no flock.
test --local_extra_resources=mem_mb=8192
