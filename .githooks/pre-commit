#!/bin/sh
# paperkit local CI — ONE Bazel target.  `bazel test //:hook` gates every project (each claim a
# per-claim check target — the bib IS the build graph, Ζ·starlark) AND grades each behaviorally
# adequate (Δ --min-strength, now hermetic under Bazel — Ζ·foot/Ξ·result-imported), so a commit
# re-runs only what changed, in parallel, with live progress — and under the hook-index
# precondition below (worktree ≡ index outside cotype/), never lands the repo broken: the
# worktree verdict IS the index verdict by substitution, at zero cache cost (Ζ·hook·index).
#
# Enable once per clone:   git config core.hooksPath .githooks
set -eu
cd "$(git rev-parse --show-toplevel)"
exec 3>&2                     # fd 3 = the terminal, for live pass-through

run() {                       # run "label" cmd...; STDERR streams live (progress reads as alive,
  desc=$1; shift              # not stalled); STDOUT is captured and shown only on failure.
  if ! out=$("$@" 2>&3); then
    echo "[pre-commit] FAIL: $desc" >&2
    echo "$out" >&2
    exit 1
  fi
  echo "[pre-commit] ok: $desc"
}

# Ζ·hook·index — the bazel run below gates the WORKING TREE; a commit lands the INDEX.  This
# precondition makes the worktree verdict THE index verdict by substitution: no divergence on
# any path outside the allowlist (cotype/ — bazel-invisible AND index-gated by its own check
# below).  Refusal is instant, BEFORE any build cost, and NAMES the paths;
# PK_HOOK_ALLOW_DIRTY=1 downgrades it to a loud advisory for a deliberate split commit.
run "hook-index (worktree ≡ index)"   mise exec -- python3 tools/hook_index.py

# Ζ·sched-batch — the grid's concurrent CPU-bound cells self-tune PER-ACTION (SCHED_BATCH + nice 19 +
# a 100ms EEVDF slice, vs the 2.8ms default) via the //tools:sched-batch-bin prefix baked into every
# pk_* action (tools/calc.bzl, tools/verb.bzl) — so a cell runs a long uninterrupted stretch instead
# of preempting a peer every ~2.8ms (measured ~30% sys / 15-20k ctx-switch/s; under zswap the refault
# churn is codec CPU, so this also cuts swap TRAFFIC si/so).  Per-action = thread-independent, the
# durable fix (Phase 1's server-tune could reach cells only nondeterministically).  Nothing to do here
# — the tuning is in the build graph; PK_SCHED_OFF=1 (an --action_env) disables it, best-effort.

# --config=mutant: the hook includes each emerge project's :cohere, whose def-sweep GRID cells
# (Ξ·dag·eval) run as counterfactuals in the HERMETIC linux-sandbox (else a check's resolve()
# escapes to the source tree → the mutation is invisible → empty sens).  The gate/adequacy checks
# pass identically under it, so the whole hook stays ONE Bazel target under one config.
# Ρ·telemetry — capture bazel's OWN per-spawn timing (--execution_log_json_file) so the
# best-effort push below can turn cycle time into a series.  The flag is a LOG sink, NOT an
# --action_env, so it changes no action key (cache-safe).  The push is OBSERVATION, never a
# gate: it runs only on a GREEN hook (run() aborts the commit on red), only when the endpoint
# env is set (default OFF ⇒ no uv fetch, no cost), and can never block a commit (|| true + the
# tool's own best-effort no-op).  It parses the log — a hermetic cell has no network to emit.
PK_EXECLOG=$(mktemp)
PK_T0=$(date +%s)
run "bazel test //:hook"   mise exec -- bazel test //:hook --config=mutant --execution_log_json_file="$PK_EXECLOG"
if [ -n "${PAPERKIT_OTLP_METRICS:-}" ]; then
  uv run --with opentelemetry-proto python3 tools/otlp_push.py "$PK_EXECLOG" \
      --build-seconds "$(( $(date +%s) - PK_T0 ))" || true
fi
rm -f "$PK_EXECLOG"

# Ξ·dag·reads — the footprint audit: every claim's declared `reads` ⊇ its live Φ·footprint (strace).
# A gate HERE, not in //:hook, for the same reason as hook-index/cotype: it must read the CURRENT
# reads= on a FRESH strace every run (no bazel caching that could serve a stale verdict when a
# reads= changes — the exact invalidation we could not prove under --config=mutant), and the standard
# env is reliably strace-capable.  ~10s.  Catches an under-declared reads UP FRONT with the exact
# remediation ("add X to the claim's `reads` field") instead of a cryptic sandbox file-not-found —
# or, as with bnd-prove's nonzero-F-arm, a red the hook MASKS.  Sound by construction: the audit's
# coverage model (own ∪ engine ∪ declared-filegroups ∪ imports) is gated by bnd-otlp-adjacent tests.
run "footprint audit (reads ⊇ Φ)"   mise exec -- python3 paperkit/footdeps.py

# Σ·cotype — cotype-monotone: ledger entry keys never vanish (append-only, retirement-logged).
# A commit-DELTA property: its truth-maker is HEAD's ledger vs the STAGED one, which only this
# hook can see (the hermetic //:hook sandbox has no git) — so the one non-bazel check lives
# here, at the layer that owns the delta, invoked as a real tool (cotype/check.py).
if git rev-parse -q --verify HEAD:cotype/ledger.md >/dev/null 2>&1; then
  old=$(mktemp); new=$(mktemp)
  git show HEAD:cotype/ledger.md > "$old"
  git show :cotype/ledger.md > "$new"
  run "cotype-monotone"    mise exec -- python3 cotype/check.py "$old" "$new"
  rm -f "$old" "$new"
fi
echo "[pre-commit] all checks passed"
