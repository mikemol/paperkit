#!/bin/sh
# paperkit local CI — ONE Bazel target.  `bazel test //:hook` gates every project (each claim a
# per-claim check target — the bib IS the build graph, Ζ·starlark) AND grades each behaviorally
# adequate (Δ --min-strength, now hermetic under Bazel — Ζ·foot/Ξ·result-imported), so a commit
# re-runs only what changed, in parallel, with live progress — and under the hook-index
# precondition below (worktree ≡ index outside cotype/), never lands the repo broken: the
# worktree verdict IS the index verdict by substitution, at zero cache cost (Ζ·hook·index).
#
# Enable once per clone:   git config core.hooksPath .githooks
set -eu
cd "$(git rev-parse --show-toplevel)"
exec 3>&2                     # fd 3 = the terminal, for live pass-through

run() {                       # run "label" cmd...; STDERR streams live (progress reads as alive,
  desc=$1; shift              # not stalled); STDOUT is captured and shown only on failure.
  if ! out=$("$@" 2>&3); then
    echo "[pre-commit] FAIL: $desc" >&2
    echo "$out" >&2
    exit 1
  fi
  echo "[pre-commit] ok: $desc"
}

# Ζ·hook·index — the bazel run below gates the WORKING TREE; a commit lands the INDEX.  This
# precondition makes the worktree verdict THE index verdict by substitution: no divergence on
# any path outside the allowlist (cotype/ — bazel-invisible AND index-gated by its own check
# below).  Refusal is instant, BEFORE any build cost, and NAMES the paths;
# PK_HOOK_ALLOW_DIRTY=1 downgrades it to a loud advisory for a deliberate split commit.
run "hook-index (worktree ≡ index)"   mise exec -- python3 tools/hook_index.py

# Ζ·sched-batch — tune the bazel server's threads (SCHED_BATCH + nice 19 + a 100ms EEVDF slice) so the
# grid's concurrent CPU-bound cells run long uninterrupted stretches instead of preempting each other
# every ~2.8ms (the default fair-class slice; measured ~30% sys / 15-20k ctx-switch/s / run-queue 2-3x
# cores — and under zswap the refault churn from short slices is codec CPU, so this also cuts swap
# TRAFFIC si/so, not just ctx-switch).  Scheduling is PER-THREAD: bazel forks action cells from its
# WORKER threads, so we tune the whole /proc/<srv>/task pool (--all-threads), not just the tgid — a
# cell forked from any worker then inherits.  PARTIAL + DECAYING: threads the server spawns AFTER this
# tune are untuned, so their cells are untuned; the DURABLE fix is a per-action self-tune (Phase 2,
# Ρ·telemetry will measure it).  Best-effort: PK_SCHED_OFF=1 disables; a missing cc or any failure is
# IGNORED (a scheduling hint never blocks a commit).  Lazy-built from tools/sched-batch.rs via rustc,
# resolved through mise (the provisioner this hook already uses for bazel — so rustc is as reachable as
# bazel) or the system PATH.
if [ -z "${PK_SCHED_OFF:-}" ]; then
  if [ ! -x tools/sched-batch ]; then
    mise exec -- rustc -O -o tools/sched-batch tools/sched-batch.rs 2>/dev/null \
      || rustc -O -o tools/sched-batch tools/sched-batch.rs 2>/dev/null || true
  fi
  if [ -x tools/sched-batch ]; then
    srv=$(mise exec -- bazel info server_pid 2>/dev/null) || srv=""            # warms + names the server
    [ -n "$srv" ] && tools/sched-batch --all-threads "$srv" 2>/dev/null || true # tune the worker pool
    echo "[pre-commit] ok: sched-batch (bazel server ${srv:-?} threads → SCHED_BATCH+nice19+100ms; partial, Phase 2 pending)"
  fi
fi

# --config=mutant: the hook includes each emerge project's :cohere, whose def-sweep GRID cells
# (Ξ·dag·eval) run as counterfactuals in the HERMETIC linux-sandbox (else a check's resolve()
# escapes to the source tree → the mutation is invisible → empty sens).  The gate/adequacy checks
# pass identically under it, so the whole hook stays ONE Bazel target under one config.
run "bazel test //:hook"   mise exec -- bazel test //:hook --config=mutant

# Σ·cotype — cotype-monotone: ledger entry keys never vanish (append-only, retirement-logged).
# A commit-DELTA property: its truth-maker is HEAD's ledger vs the STAGED one, which only this
# hook can see (the hermetic //:hook sandbox has no git) — so the one non-bazel check lives
# here, at the layer that owns the delta, invoked as a real tool (cotype/check.py).
if git rev-parse -q --verify HEAD:cotype/ledger.md >/dev/null 2>&1; then
  old=$(mktemp); new=$(mktemp)
  git show HEAD:cotype/ledger.md > "$old"
  git show :cotype/ledger.md > "$new"
  run "cotype-monotone"    mise exec -- python3 cotype/check.py "$old" "$new"
  rm -f "$old" "$new"
fi
echo "[pre-commit] all checks passed"
