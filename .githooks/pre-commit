#!/bin/sh
# paperkit local CI — every check lives in a bib, and the gate runs each project's
# checks IN PARALLEL (the bib is the makefile).  A commit must leave every project
# green: prose ≡ projection, every cited check passing, zero postulates (--safe),
# distinct witnesses (--without-K), and the paper behaviorally adequate (Δ).
#
# The tool boundary suites (⟨P,F,δ⟩) are CLAIMS in the `boundaries` project, so a new
# tool's suite is gated the moment its claim lands — there is no suite list here to
# forget.  To gate a new document, add its project dir to the loop below.
#
# Enable once per clone:   git config core.hooksPath .githooks
set -eu
cd "$(git rev-parse --show-toplevel)"

run() {                       # run "label" cmd...; show output only on failure
  desc=$1; shift
  if ! out=$("$@" 2>&1); then
    echo "[pre-commit] FAIL: $desc" >&2
    echo "$out" >&2
    exit 1
  fi
  echo "[pre-commit] ok: $desc"
}

run "gate paper (--safe --without-K)"       python3 paperkit/gate.py --safe --without-K paper
run "gate README (--safe --without-K)"      python3 paperkit/gate.py --safe --without-K .
run "gate boundaries (--safe --without-K)"  python3 paperkit/gate.py --safe --without-K boundaries
run "Δ adequacy: paper all-behavioral"      python3 paperkit/discriminate.py --min-strength behavioral paper
echo "[pre-commit] all checks passed"
