#!/bin/sh
# paperkit local CI — every commit must leave the repository green: both documents
# project-stable, every check passing, zero postulates (--safe), and the tool
# boundaries intact.  This hook IS our CI; add every new check here.
#
# Enable once per clone:   git config core.hooksPath .githooks
set -eu
cd "$(git rev-parse --show-toplevel)"

run() {                       # run "label" cmd...; show output only on failure
  desc=$1; shift
  if ! out=$("$@" 2>&1); then
    echo "[pre-commit] FAIL: $desc" >&2
    echo "$out" >&2
    exit 1
  fi
  echo "[pre-commit] ok: $desc"
}

run "gate paper/ (--safe, --without-K)"       python3 paperkit/gate.py --safe --without-K paper
run "Δ adequacy: paper all-behavioral"        python3 paperkit/discriminate.py --min-strength behavioral paper
run "gate README (--safe, --without-K)"       python3 paperkit/gate.py --safe --without-K .
run "Δ behavioral boundaries"                python3 paperkit/tests/boundaries_discriminate.py
run "engine boundaries (emit / --safe)"      python3 paperkit/tests/boundaries_emit.py
run "witness boundaries (--without-K)"       python3 paperkit/tests/boundaries_without_k.py
run "gate --json boundaries"                 python3 paperkit/tests/boundaries_gate_json.py
run "driver boundaries (pump/parse)"         python3 paperkit/tests/boundaries_driver.py
run "Μ cache boundaries"                      python3 paperkit/tests/boundaries_memoize.py
echo "[pre-commit] all checks passed"
