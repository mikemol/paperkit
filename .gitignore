__pycache__/
*.pyc
.delta-cache.json
setup/.loadtest.lock

# Bazel convenience symlinks (point into the GB-scale cache; must never enter git or the Δ sandbox)
/bazel-*

# inbox/ — a drop point for OTHER sessions' findings and bug reports, deliberately outside this
# session's live git state.  Its README is tracked; incoming drops stay ignored; SETTLED
# correspondence is promoted into inbox/archive/ (tracked) by a deliberate human act.
/inbox/*
!/inbox/README.md
!/inbox/archive/

# Ζ·sched-batch — the lazy-built helper binary (arch-specific; source tools/sched-batch.rs is tracked)
tools/sched-batch
