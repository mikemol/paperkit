% warrants.bib — paperkit's tools and their behavioral boundaries.  Each claim is a
% tool's ⟨P, F, δ⟩ lint suite (the boundary practice): the prose states what the tool
% flags and what it passes; the `check` RUNS that suite.  This file is a makefile —
% the gate runs every check below in parallel — and BOUNDARIES.md is its projection.

% ── Δ grader + --without-K ───────────────────────────────────────────────────
@misc{bnd-delta,
  section = {delta},
  claim   = {the Δ grader's boundary --- it flags a check that provably cannot fail (vacuous) and passes one a mutation can break (behavioral)},
  check   = {cmd:python3 ../paperkit/tests/boundaries_discriminate.py}
}
@misc{bnd-witness,
  section = {delta}, from = {bnd-delta}, join = {. },
  claim   = {the --without-K boundary --- it flags two cited claims that share a single witness and passes claims that carry distinct witnesses},
  check   = {cmd:python3 ../paperkit/tests/boundaries_without_k.py}
}
@misc{bnd-coherence,
  section = {delta}, from = {bnd-witness}, join = {. },
  claim   = {the ∂² coherence residual --- it reports zero when a claim's from and rests-on edges agree and when witnesses carry distinct sensitivities, and surfaces the divergence and the collapse otherwise},
  check   = {cmd:python3 ../paperkit/tests/boundaries_coherence.py}
}

% ── projector + gate ─────────────────────────────────────────────────────────
@misc{bnd-emit,
  section = {engine},
  claim   = {the projector's boundary --- it emits a cited example verbatim, and --safe rejects an uncited placement (a postulate)},
  check   = {cmd:python3 ../paperkit/tests/boundaries_emit.py}
}
@misc{bnd-json,
  section = {engine}, from = {bnd-emit}, join = {. },
  claim   = {the gate --json boundary --- the structured fields track the gate's actual verdict, the pass flag and witness collapses included},
  check   = {cmd:python3 ../paperkit/tests/boundaries_gate_json.py}
}
@misc{bnd-parallel,
  section = {engine}, from = {bnd-json}, join = {. },
  claim   = {the parallel gate's boundary --- the verdict tracks the checks, never the worker count or a check's memory lease, so fanning out (and routing heavy checks through the membudget semaphore) equals running serially},
  check   = {cmd:python3 ../paperkit/tests/boundaries_jobs.py}
}
@misc{bnd-env,
  section = {engine}, from = {bnd-parallel}, join = {. },
  claim   = {the environment boundary --- a check runs in a controlled, default-deny environment (sshd's defence against env injection), keeping PATH, locale, and paperkit's own knobs but dropping LD_PRELOAD, IFS, BASH_ENV, and the like, and dropping PATH's relative entries so a tool cannot resolve to the gated project dir},
  check   = {cmd:python3 ../paperkit/tests/boundaries_env.py}
}
@misc{bnd-references,
  section = {engine}, from = {bnd-env}, join = {. },
  claim   = {the reference projector's boundary --- a non-adjacent grounding edge projects as a direction-aware cross-reference, an adjacent one is carried by the connective, and a target reachable by a longer grounding path is dropped as redundant},
  check   = {cmd:python3 ../paperkit/tests/boundaries_references.py}
}
@misc{bnd-footprint,
  section = {engine}, from = {bnd-references}, join = {. },
  claim   = {the footprint tracer's boundary (Φ) --- a check's READ footprint is exactly the project files it opens when it runs, growing by each file it reads, and it is a superset of the sensitivity set, so a corruption-blind check still reports the input it reads --- the gap that makes the read footprint, not sensitivity, the sound key to cache a grade on},
  check   = {cmd:python3 ../paperkit/tests/boundaries_footprint.py}
}

% ── driver + cache ───────────────────────────────────────────────────────────
@misc{bnd-driver,
  section = {runtime},
  claim   = {the driver's boundary --- a witness pumps and serializes resumably, so a slow check is interruptible, not broken},
  check   = {cmd:python3 ../paperkit/tests/boundaries_driver.py}
}
@misc{bnd-cache,
  section = {runtime}, from = {bnd-driver}, join = {. },
  claim   = {the memoization boundary --- a grade is reused only when the content key matches, so a changed engine never serves a stale grade},
  check   = {cmd:python3 ../paperkit/tests/boundaries_memoize.py}
}
@misc{bnd-agree,
  section = {engine}, from = {bnd-footprint}, join = {. },
  claim   = {the agree verb's boundary (Δ·agree) --- independent producers that concur pass, a single byte of disagreement flags, and neither a lone producer nor one that fails can concur, so the verb corroborates a fact across implementations rather than trusting one},
  check   = {cmd:python3 ../paperkit/tests/boundaries_agree.py}
}
@misc{bnd-corroboration,
  section = {delta}, from = {bnd-coherence}, join = {. },
  claim   = {the corroboration axis (Ε·agree·grade) --- a grade is the pair (falsifiability, corroboration), not one scalar: an agree: verdict from independent producers is marked independently corroborated while a lone witness or identical producers stay single, so a behavioral cmd: and a behavioral agree: share a grade yet differ on this orthogonal axis},
  check   = {cmd:python3 ../paperkit/tests/boundaries_corroboration.py}
}
@misc{bnd-sandbox,
  section = {runtime}, from = {bnd-cache}, join = {. },
  claim   = {the Δ sandbox's boundary --- the mutation copy takes the bounded root WHOLE (the bound lives on the root, not a lossy per-dir skip), and that root is DECLARABLE (the PAPERKIT_ROOT environment variable, which a --root flag overrides, or paper.toml) and otherwise inferred as the parent --- but inferring a home directory or above is REFUSED with guidance, so a downstream project living in a home that also holds a clone or cache does not explode the disk},
  check   = {cmd:python3 ../paperkit/tests/boundaries_sandbox.py}
}
