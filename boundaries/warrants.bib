% warrants.bib — paperkit's tools and their behavioral boundaries.  Each claim is a
% tool's ⟨P, F, δ⟩ lint suite (the boundary practice): the prose states what the tool
% flags and what it passes; the `check` RUNS that suite.  This file is a makefile —
% the gate runs every check below in parallel — and BOUNDARIES.md is its projection.

% ── Δ grader + --without-K ───────────────────────────────────────────────────
@misc{bnd-delta,
  section = {delta},
  claim   = {the Δ grader's boundary --- it flags a check that provably cannot fail (vacuous) and passes one a mutation can break (behavioral), and a def-resolution sweep that cannot find the engine in its sandbox fails loudly rather than silently degrading to file resolution},
  check   = {cmd:python3 ../paperkit/tests/boundaries_discriminate.py}
}
@misc{bnd-witness,
  section = {delta}, from = {bnd-delta}, join = {. },
  claim   = {the --without-K boundary --- it flags two cited claims that share a single witness and passes claims that carry distinct witnesses},
  check   = {cmd:python3 ../paperkit/tests/boundaries_without_k.py}
}
@misc{bnd-coherence,
  section = {delta}, from = {bnd-witness}, join = {. },
  claim   = {the ∂² coherence residual --- it reports zero when a claim's from and rests-on edges agree and when witnesses carry distinct sensitivities, surfaces the divergence and the collapse otherwise, and refuses a verdict when no claim tests any engine capability at all (a vacuous measurement)},
  check   = {cmd:python3 ../paperkit/tests/boundaries_coherence.py}
}

% ── projector + gate ─────────────────────────────────────────────────────────
@misc{bnd-emit,
  section = {engine},
  claim   = {the projector's boundary --- it emits a cited example verbatim, and --safe rejects an uncited placement (a postulate)},
  check   = {cmd:python3 ../paperkit/tests/boundaries_emit.py}
}
@misc{bnd-json,
  section = {engine}, from = {bnd-emit}, join = {. },
  claim   = {the gate --json boundary --- the structured fields track the gate's actual verdict, the pass flag and witness collapses included},
  check   = {cmd:python3 ../paperkit/tests/boundaries_gate_json.py}
}
@misc{bnd-parallel,
  section = {engine}, from = {bnd-json}, join = {. },
  claim   = {the parallel gate's boundary --- the verdict tracks the checks, never the worker count or the memory reservation (the learned mem.json that the bib generator projects to a per-sweep Bazel resource_set, bounding concurrent sweeps against the host RAM pool; the engine itself is inert to it), so fanning out equals running serially},
  check   = {cmd:python3 ../paperkit/tests/boundaries_jobs.py}
}
@misc{bnd-env,
  section = {engine}, from = {bnd-parallel}, join = {. },
  claim   = {the environment boundary --- a check runs in a controlled, default-deny environment (sshd's defence against env injection), keeping PATH, locale, and paperkit's own knobs but dropping LD_PRELOAD, IFS, BASH_ENV, and the like, and dropping PATH's relative entries so a tool cannot resolve to the gated project dir},
  check   = {cmd:python3 ../paperkit/tests/boundaries_env.py}
}
@misc{bnd-references,
  section = {engine}, from = {bnd-env}, join = {. },
  claim   = {the reference projector's boundary --- a non-adjacent grounding edge projects as a direction-aware cross-reference, an adjacent one is carried by the connective, and a target reachable by a longer grounding path is dropped as redundant},
  check   = {cmd:python3 ../paperkit/tests/boundaries_references.py}
}
@misc{bnd-footprint,
  section = {engine}, from = {bnd-references}, join = {. },
  claim   = {the footprint tracer's boundary (Φ) --- a check's READ footprint is exactly the project files it opens when it runs, growing by each file it reads, and it is a superset of the sensitivity set, so a corruption-blind check still reports the input it reads --- the gap that makes the read footprint, not sensitivity, the sound key to cache a grade on},
  check   = {cmd:python3 ../paperkit/tests/boundaries_footprint.py}
}

% ── driver + cache ───────────────────────────────────────────────────────────
@misc{bnd-driver,
  section = {runtime},
  claim   = {the driver's boundary --- a witness pumps and serializes resumably, so a slow check is interruptible, not broken},
  check   = {cmd:python3 ../paperkit/tests/boundaries_driver.py}
}
@misc{bnd-cache,
  section = {runtime}, from = {bnd-driver}, join = {. },
  claim   = {the memoization boundary --- a grade is reused only when the content key matches, so a changed engine never serves a stale grade},
  check   = {cmd:python3 ../paperkit/tests/boundaries_memoize.py}
}
@misc{bnd-agree,
  section = {engine}, from = {bnd-footprint}, join = {. },
  claim   = {the agree verb's boundary (Δ·agree) --- independent producers that concur pass, a single byte of disagreement flags, and neither a lone producer nor one that fails can concur, so the verb corroborates a fact across implementations rather than trusting one},
  check   = {cmd:python3 ../paperkit/tests/boundaries_agree.py}
}
@misc{bnd-corroboration,
  section = {delta}, from = {bnd-coherence}, join = {. },
  claim   = {the corroboration axis (Ε·agree·grade) --- a grade is the pair (falsifiability, corroboration), not one scalar: an agree: verdict from independent producers is marked independently corroborated while a lone witness or identical producers stay single, so a behavioral cmd: and a behavioral agree: share a grade yet differ on this orthogonal axis},
  check   = {cmd:python3 ../paperkit/tests/boundaries_corroboration.py}
}
@misc{bnd-sandbox,
  section = {runtime}, from = {bnd-cache}, join = {. },
  claim   = {the Δ sandbox's boundary --- the mutation copy takes the bounded root WHOLE (the bound lives on the root, not a lossy per-dir skip) save for SKIP_DIRS, which prune .git and the bazel-* cache links from both the copy and the deep nested-project walk so an artifact never explodes the sandbox, and that root is DECLARABLE (the PAPERKIT_ROOT environment variable, which a --root flag overrides, or paper.toml) and otherwise inferred as the parent --- but inferring a home directory or above is REFUSED with guidance, so a downstream project living in a home that also holds a clone or cache does not explode the disk},
  check   = {cmd:python3 ../paperkit/tests/boundaries_sandbox.py}
}
@misc{bnd-config,
  section = {engine}, from = {bnd-agree}, join = {. },
  claim   = {the configurable pipeline's boundary (Ω·config) --- every knob resolves the one way, explicit arg over env over project config over default, a value outside its choices is refused, and apply_args captures args PROCESS-LOCALLY so a check the grader spawns never inherits the grader's own flags; and the entry-registry completeness boundary (Μ·kernel·shrink·registry) --- each knob is declared in the module that RESOLVES it, the kernel hosts none, and every CLI entry's composed registry equals exactly the Params its import cone hosts, derived from dag.bzl and introspection, so a cone-resolved flag can never be silently ignored},
  check   = {cmd:python3 ../paperkit/tests/boundaries_config.py},
  reads   = {.}
}
@misc{bnd-degrade,
  section = {engine}, from = {bnd-config}, join = {. },
  claim   = {footprint's degradation boundary (Φ·degrade) --- when strace is absent or cannot attach, the read footprint returns the sentinel None rather than crashing or returning an empty list, so the grade is swept over the full surface and left uncached instead of over-reused under an empty footprint},
  check   = {cmd:python3 ../paperkit/tests/boundaries_degrade.py}
}
@misc{bnd-path,
  section = {engine}, from = {bnd-degrade}, join = {. },
  claim   = {tool-path pinning's boundary (Τ·path) --- by default a check resolves its tools from the host's absolute PATH entries, deduplicated, but when PAPERKIT_PATH is declared resolution is PINNED to exactly those absolute existing dirs and the ambient, user-writable host PATH is dropped entirely, so the same tool resolves on any host},
  check   = {cmd:python3 ../paperkit/tests/boundaries_path.py}
}
@misc{bnd-target,
  section = {engine}, from = {bnd-path}, join = {. },
  claim   = {the render-target boundary (Ρ·render·web) --- one common projector renders a claim's grounding the SAME edge two ways by target: a pandoc citeproc citation, or for the web target an intra-page hyperlink to the grounded claim's anchor, every link resolving to an anchor present in the document --- the target a config knob, not a new authoring syntax},
  check   = {cmd:python3 ../paperkit/tests/boundaries_target.py}
}
@misc{bnd-check,
  section = {engine}, from = {bnd-target}, join = {. },
  claim   = {the recursive check graph's boundary (Ζ·bnd-check) --- the Bazel build graph is ONE mechanism (every project wired by the same bib.project tag, //:hook a single test_suite of uniform per-claim gate and adequacy targets) and the local CI is COMPLETE: //:hook carries both the gate and the Delta adequacy target of every graded project, so bazel test //:hook gates AND grades every document, and carries the ONE harness canary (a guaranteed-flip positive control that fails LOUD when the mutation sandbox degrades, named as the exact non-project member by set-equality)},
  check   = {cmd:python3 ../paperkit/tests/boundaries_check.py},
  reads   = {.}
}
@misc{bnd-components,
  section = {engine}, from = {bnd-check}, join = {. },
  claim   = {the engine itself is partitioned into components (Μ·kernel·bounds) --- kernel, model, resolver, project, gate, delta, tests --- declared once in components.bzl, TOTAL and DISJOINT over the real tree by set-equality, with an acyclic allowed-import DAG that every real import edge is verified against, the committed import map (dag.bzl) first re-derived through its owning tool so the discipline is never judged on a stale copy},
  check   = {cmd:python3 ../paperkit/tests/boundaries_components.py},
  reads   = {.}
}
@misc{bnd-lint,
  section = {engine}, from = {bnd-components}, join = {. },
  claim   = {the build rules hold to the same boundary --- every .bzl action INVOKES a tool rather than embedding a script, so a bare interpreter (which leaves sys.executable empty), a printf-built JSON record, or a grep-parsed JSON field cannot enter a command string, and the verdict record has one owner (tools/verdict.py); Ξ·lint blocks all three across every .bzl},
  check   = {cmd:python3 ../tools/lint_bzl.py ../tools/calc.bzl ../tools/verb.bzl ../tools/grade.bzl ../tools/bibtex.bzl ../tools/witness.bzl},
  reads   = {.}
}
@misc{bnd-toplevel,
  section = {engine}, from = {bnd-lint}, join = {. },
  claim   = {a claim-witness module's TOP LEVEL carries no engine-source reads (Ζ·bnd·toplevel) --- a module-level convenience becomes a staged input of EVERY grid row (one engine edit re-keys the whole grid), so a source inspection lives INSIDE the witness that makes it, scoped to exactly its rows; the witness set is discovered from the paper.tomls and the read semantics derive from closure.py, the owner},
  check   = {cmd:python3 ../paperkit/tests/boundaries_toplevel.py},
  reads   = {., paper, library}
}
@misc{bnd-grounding,
  section = {engine}, from = {bnd-toplevel}, join = {. },
  claim   = {the grounding closure's boundary --- the gate resolves the TRANSITIVE rests-on cone of the cited/placed set on every render target (a sectionless premise two hops away fails the gate when its check breaks, a cycle terminates, and a rests-on edge to an undefined key is a broken grounding that fails the gate), an unreachable sectionless node's check stays un-gated, and Delta grades the cone too},
  check   = {cmd:python3 ../paperkit/tests/boundaries_grounding.py}
}
@misc{bnd-dispatch,
  section = {engine}, from = {bnd-grounding}, join = {. },
  claim   = {the check-TYPE registry's boundary --- the built-in verb set is DECLARED once as data (resolver.VERBS), and every site that dispatches on a check's type derives from it rather than carrying a copy: a verb is not MIGRATED when its verdict works but when the verdict path, the grade path, the footprint audit and the generator all agree about it, and a verb that CROSSES a project boundary (crosses=True) is delegated to its owner by all of them at once --- so a new verb cannot reach the gate green while a site the gate cannot see still reads the old set},
  check   = {cmd:python3 ../paperkit/tests/boundaries_dispatch.py},
  reads   = {.}
}
@misc{bnd-ladder,
  section = {engine}, from = {bnd-dispatch}, join = {, and }, rests-on = {bnd-dispatch},
  claim   = {the grade LADDER's boundary is the same shape --- the rungs are declared once (grade.RANK_C) and every consumer that orders, displays or gates on them DERIVES, because a re-declared ladder drifts in two opposite directions at once: a display order missing a rung silently under-counts its own population, and an adequacy floor written as a BLACKLIST of failing grades fails OPEN, admitting every rung added after the list was written --- so the floor is named and its failing set derived, which judges a new rung the moment it exists},
  check   = {cmd:python3 ../paperkit/tests/boundaries_ladder.py},
  reads   = {.}
}
@misc{bnd-surface,
  section = {engine}, from = {bnd-ladder}, join = {. },
  claim   = {the mutation SURFACE has a boundary of its own, and the grade must say where it runs --- a claim's falsifiability is measured over the inputs the sweep can corrupt, so an input it merely READS and cannot mutate (excluded by suffix, or living outside the project entirely) leaves the grade narrower than it looks, and reporting that gap is what keeps indeterminate meaning ONE thing: every input was corrupted and none flipped it, never we did not look --- an orthogonal axis like corroboration, never a rung, since incompleteness is not a weaker grade and no adequacy floor may fail a claim for it},
  check   = {cmd:python3 ../paperkit/tests/boundaries_surface.py}
}
