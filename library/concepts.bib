% concepts.bib — the concept-witness LIBRARY's own records: one entry per concept FACE, each a
% cmd: witness the library GRADES once (a def-sweep → the certificate every VIEW imports).  The
% prose faces (the README pitch, the paper deep exposition) are authored in their own views; these
% are the minimal grading records that OWN the certificate.  Two keys share one witness
% (concepts.py maps both to adequacy_pitch) so each view imports under the key it cites.

@misc{adequacy-pitch,
  section = {adequacy},
  claim   = {the adequacy witness runs the real grader over a fixture, so mutating an engine def-site flips it --- the certificate's sensitivity fingerprint IS the engine, which every importing view inherits},
  check   = {cmd:python3 concepts.py adequacy-pitch}
}

@misc{grade-ladder,
  section = {adequacy},
  claim   = {the same witness under the deep key certifies the grade ladder --- a presupposed file grades vacuous, a content-sensitive command behavioral --- so the paper's deep exposition imports the identical proof the pitch does},
  check   = {cmd:python3 concepts.py grade-ladder}
}

@misc{rm-model,
  section = {model},
  claim   = {a claim is one bibliography entry --- a statement, its rubric section, its dependencies, and its check --- parsed by the engine's OWN bib reader, so mutating a parser def-site flips the witness and the certificate's fingerprint IS that parser},
  check   = {cmd:python3 concepts.py rm-model}
}

@misc{claim-is-record,
  section = {model},
  claim   = {the same witness under the paper's key certifies that a claim is a single record --- the deep view imports the identical proof the README pitch does},
  check   = {cmd:python3 concepts.py claim-is-record}
}

@misc{rm-verifier,
  section = {resolver},
  claim   = {each claim carries a machine-checkable verifier --- the check field names a verb and the gate RESOLVES it; the parser and the resolver are engine, so the certificate's fingerprint is them},
  check   = {cmd:python3 concepts.py rm-verifier}
}

@misc{claim-bears-check,
  section = {resolver},
  claim   = {the same witness under the paper's key certifies that each claim bears a machine-checkable verifier},
  check   = {cmd:python3 concepts.py claim-bears-check}
}

@misc{rm-resolver-cmd,
  section = {resolver},
  claim   = {cmd is the escape hatch every check reduces to, and a new domain adds a verifier in config without touching the engine --- a config-supplied type resolves, an unregistered one does not},
  check   = {cmd:python3 concepts.py rm-resolver-cmd}
}

@misc{cmd-escape,
  section = {resolver},
  claim   = {the paper's cmd-escape face imports this same certificate --- cmd is the universal escape hatch every other check reduces to},
  check   = {cmd:python3 concepts.py cmd-escape}
}

@misc{new-domain-adds,
  section = {resolver},
  claim   = {and the paper's new-domain-adds face too --- supporting a new domain means adding verifiers, not editing the engine},
  check   = {cmd:python3 concepts.py new-domain-adds}
}

@misc{rm-noship,
  section = {gate},
  claim   = {an unverified sentence cannot ship --- a claim whose check FAILS blocks the gate; the gate is engine, so its def-sites are the fingerprint},
  check   = {cmd:python3 concepts.py rm-noship}
}

@misc{fail-omits,
  section = {gate},
  claim   = {the paper's fail-omits face imports this same certificate --- a claim whose verifier fails simply does not appear in the prose},
  check   = {cmd:python3 concepts.py fail-omits}
}

@misc{rm-cmds-inv,
  section = {gate},
  claim   = {the gate ENFORCES its invariants --- the committed prose equals its projection, and every cited claim's check passes --- so violating each makes it RED},
  check   = {cmd:python3 concepts.py rm-cmds-inv}
}

@misc{gate-is-subject,
  section = {gate},
  claim   = {the paper's self-host face imports this same certificate --- the gate that accepts the paper is the very subject it describes, enforcing the invariants the paper states},
  check   = {cmd:python3 concepts.py gate-is-subject}
}

@misc{rm-resolver,
  section = {resolver},
  claim   = {the resolver component's certificate --- a verifier is named type:target, EVERY declared verb dispatches to a real branch (read from resolver.VERBS, nothing re-listed), the built-in set is closed, and a custom type dispatches through the registry},
  check   = {cmd:python3 concepts.py rm-resolver}
}

@misc{verifier-named,
  section = {resolver},
  claim   = {the paper's verifier-named face imports this certificate --- the type prefix selects the verb},
  check   = {cmd:python3 concepts.py verifier-named}
}

@misc{gate-dispatches,
  section = {resolver},
  claim   = {and its gate-dispatches face --- the gate dispatches through a small registry of check types, built-in and custom},
  check   = {cmd:python3 concepts.py gate-dispatches}
}

@misc{two-builtins,
  section = {resolver},
  claim   = {and its two-builtins face --- a verifier ships built in per verb, and the set is pinned ENUMERATIVELY rather than by count, closing the adequacy gap that let a fifth verb falsify the prose silently},
  check   = {cmd:python3 concepts.py two-builtins}
}

@misc{rm-pitch,
  section = {projector},
  claim   = {the projector component's certificate --- a document IS the projection of its claim-DAG: the title, every rubric section, and every claim's prose appear in the emitted document, which leads with a heading},
  check   = {cmd:python3 concepts.py rm-pitch}
}

@misc{paper-is-projection,
  section = {projector},
  claim   = {the paper's thesis face imports this certificate --- a scholarly paper as the projection of a claim-DAG},
  check   = {cmd:python3 concepts.py paper-is-projection}
}

@misc{projector-emits,
  section = {projector},
  claim   = {and its engine face --- the projector emits the whole document from the warrant set, populated sections and empty ones alike},
  check   = {cmd:python3 concepts.py projector-emits}
}

@misc{rm-cmds,
  section = {projector},
  claim   = {two commands do the work --- PROJECT makes the document and GATE verifies it: the exact projection passes, hand-edited drift is rejected},
  check   = {cmd:python3 concepts.py rm-cmds}
}

@misc{gate-rejects-drift,
  section = {projector},
  claim   = {the paper's drift face imports this same certificate --- the gate rejects any prose that has drifted from its projection},
  check   = {cmd:python3 concepts.py gate-rejects-drift}
}
