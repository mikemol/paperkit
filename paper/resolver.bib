% resolver.bib — the check-resolver — one pluggable seam
% A concept module of the paper's warrant library; composed by paper.toml.

@misc{verifier-named,
  section = {resolver}, from = {claim-bears-check},
  claim   = {a claim's verifier is named type:target},
  check   = {claim:verifier-named}
}

@misc{gate-dispatches,
  section = {resolver}, from = {verifier-named}, join = {, and },
  claim   = {the gate dispatches it through a small registry of check types},
  rests-on = {verifier-named},
  check   = {claim:gate-dispatches}
}

@misc{new-domain-adds,
  section = {resolver}, from = {gate-dispatches}, join = {, so },
  claim   = {supporting a new domain means adding verifiers, not editing the engine},
  rests-on = {gate-dispatches},
  check   = {claim:new-domain-adds}
}

@misc{two-builtins,
  section = {resolver}, from = {gate-dispatches}, join = {. },
  claim   = {four verifiers ship built in, one per verb},
  rests-on = {file-builtin, cmd-builtin, result-builtin, agree-builtin},
  link    = {grounded by the four builtins it names, which the prose introduces just after --- the grounding link runs counter to prose order},
  check   = {claim:two-builtins}
}

@misc{file-builtin,
  section = {resolver}, from = {two-builtins}, join = { — },
  claim   = {file, that an artifact EXISTS},
  check   = {claim:file-builtin}
}

@misc{cmd-builtin,
  section = {resolver}, from = {two-builtins}, join = {, },
  claim   = {cmd, that a script EXECS green},
  check   = {claim:cmd-builtin}
}

@misc{result-builtin,
  section = {resolver}, from = {cmd-builtin}, join = {, },
  claim   = {result, that a sibling project's gate verdict PARSES green --- the verb that lets one project rest on another it does not re-derive},
  check   = {claim:result-builtin}
}

@misc{agree-builtin,
  section = {resolver}, from = {result-builtin}, join = {, and },
  claim   = {agree, that N independent producers CONCUR --- all exit green and emit identical output, the verb that corroborates a fact across implementations rather than trusting one (Δ·agree)},
  check   = {claim:agree-builtin}
}

@misc{cmd-escape,
  section = {resolver}, from = {cmd-builtin, new-domain-adds}, join = {; and },
  claim   = {cmd is the universal escape hatch every other check reduces to},
  rests-on = {cmd-builtin, new-domain-adds},
  check   = {claim:cmd-escape}
}

@misc{dataset-backed,
  section = {resolver}, from = {cmd-escape}, join = {. },
  claim   = {Pointed at a dataset the project SHIPS rather than a transient command, that hatch turns a claim's evidence into a versioned artifact --- a captured snapshot, a generated figure --- that anyone can re-read and a single edit can falsify},
  rests-on = {new-domain-adds},
  check   = {claim:dataset-backed}
}

@misc{dataset-fresh,
  section = {resolver}, from = {dataset-backed}, join = {, kept honest because },
  claim   = {the verifier re-runs the producer that built that dataset and fails on drift --- shipped evidence that is fresh by construction, not a figure pasted in once and quietly gone stale},
  rests-on = {dataset-backed},
  check   = {claim:dataset-fresh}
}
