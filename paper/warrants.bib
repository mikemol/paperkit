% warrants.bib — the claims of this paper, decomposed to the smallest INDEPENDENTLY
% CHECKABLE proposition (recursive sentence-diagramming).  Each entry is one
% constituent: a statement (claim), its rubric section, its dependency (from), the
% grammatical attachment to its predecessor (join), and its verifier (check).  The
% projector re-weaves the constituents into prose along the `join` edges; the gate
% passes iff every cited constituent's check passes.  check grammar:
%   file:<path>   the artifact exists, relative to paper/
%   cmd:<script>  run it from paper/; exit 0 = pass
% The decomposition stops exactly where a finer split would leave a fragment that
% can carry no check of its own (a bare adjective, an appositive noun-list).

% ── 1. intro ────────────────────────────────────────────────────────────────
@misc{paper-is-projection,
  section = {intro},
  claim   = {paperkit treats a scholarly paper as the projection of a claim-DAG},
  rests-on = {fail-omits, gate-rejects-drift, prose-projected},
  check   = {claim:paper-is-projection}
}
@misc{node-is-claim,
  section = {intro}, from = {paper-is-projection}, join = { — },
  claim   = {each node a single claim},
  check   = {claim:node-is-claim}
}
@misc{claim-bears-check,
  section = {intro}, from = {node-is-claim}, join = {, },
  claim   = {each claim carrying a machine-checkable verifier},
  rests-on = {node-is-claim},
  check   = {claim:claim-bears-check}
}
@misc{fail-omits,
  section = {intro}, from = {claim-bears-check, paper-is-projection}, join = {; and },
  claim   = {a claim whose verifier fails simply does not appear in the prose},
  rests-on = {claim-bears-check, prose-projected, gate-rejects-drift},
  check   = {claim:fail-omits}
}

% ── 2. model ────────────────────────────────────────────────────────────────
@misc{claim-is-record,
  section = {model}, from = {node-is-claim, claim-bears-check},
  claim   = {a claim is a single record --- a statement, the rubric section it belongs to, its dependencies, and its verifier},
  rests-on = {node-is-claim, claim-bears-check},
  check   = {claim:claim-is-record}
}
@misc{record-is-bibentry,
  section = {model}, from = {claim-is-record}, join = { — },
  claim   = {which is exactly the shape of a bibliography entry},
  rests-on = {claim-is-record},
  check   = {claim:record-is-bibentry}
}
@misc{prose-projected,
  section = {model}, from = {paper-is-projection}, join = {. },
  claim   = {the prose is projected, not authored},
  rests-on = {projector-emits, ordered-by-deps, joined-by-glue},
  check   = {claim:prose-projected}
}
@misc{ordered-by-deps,
  section = {model}, from = {prose-projected}, join = {: },
  claim   = {within each section the claims are ordered by their dependency edges},
  rests-on = {projector-emits},
  check   = {claim:ordered-by-deps}
}
@misc{joined-by-glue,
  section = {model}, from = {ordered-by-deps}, join = { and },
  claim   = {joined by connective glue},
  rests-on = {projector-emits},
  check   = {claim:joined-by-glue}
}
@misc{deterministic,
  section = {model}, from = {ordered-by-deps, joined-by-glue}, join = {, },
  claim   = {the same warrant set always giving the same document},
  rests-on = {ordered-by-deps, joined-by-glue},
  check   = {claim:deterministic}
}

% ── edges: the three dependency graphs ──────────────────────────────────────
@misc{edge-from-orders,
  section = {edges},
  claim   = {a claim's from-edges fix its place in the prose --- the projector emits a claim only after the claims it lists, so document order is a topological sort of the from-graph},
  check   = {claim:edge-from-orders}
}
@misc{edge-rests-grounds,
  section = {edges}, from = {edge-from-orders}, join = {. },
  claim   = {rests-on is a separate grounding edge --- a claim's effective grade is clamped to the weakest grade along it, regardless of prose order},
  check   = {claim:edge-rests-grounds}
}
@misc{edge-chiral,
  section = {edges}, from = {edge-rests-grounds}, join = {, and },
  claim   = {the two graphs are independent and often reversed: prose runs general to specific while grounding runs specific to general, so one pair of claims is at once a forward prose edge and a backward grounding edge},
  check   = {claim:edge-chiral}
}
@misc{edge-move-types,
  section = {edges}, from = {edge-chiral}, join = {. },
  claim   = {the move field names the typed rhetorical relation binding a claim to the prior beat --- its kind decides its role (an entail move also grounds; turn, extend, parallel, and restate moves are prose only) and a section's declared scheme admits only certain move-kinds},
  check   = {claim:edge-move-types}
}

% ── 3. engine ───────────────────────────────────────────────────────────────
@misc{projector-emits,
  section = {engine}, from = {prose-projected},
  claim   = {the projector emits the whole document from the warrant set},
  check   = {claim:projector-emits}
}
@misc{prose-is-artifact,
  section = {engine}, from = {projector-emits}, join = {, so },
  claim   = {the committed prose is a build artifact, not a source any hand should edit},
  rests-on = {projector-emits, prose-projected},
  check   = {claim:prose-is-artifact}
}
@misc{gate-rejects-drift,
  section = {engine}, from = {prose-is-artifact}, join = {. },
  claim   = {the gate rejects any prose that has drifted from its projection},
  rests-on = {prose-is-artifact},
  check   = {claim:gate-rejects-drift}
}
@misc{edit-cant-survive,
  section = {engine}, from = {gate-rejects-drift, projector-emits}, join = {, so },
  claim   = {a hand-edit cannot survive a build},
  rests-on = {gate-rejects-drift, projector-emits},
  check   = {claim:edit-cant-survive}
}
@misc{coverage-both-sides,
  section = {engine}, from = {gate-rejects-drift}, join = {. },
  claim   = {coverage is enforced from both sides},
  rests-on = {every-section-appears, every-claim-cited},
  check   = {claim:coverage-both-sides}
}
@misc{every-section-appears,
  section = {engine}, from = {coverage-both-sides}, join = { — },
  claim   = {every required section must appear},
  check   = {claim:every-section-appears}
}
@misc{every-claim-cited,
  section = {engine}, from = {coverage-both-sides}, join = {, and },
  claim   = {every claim tagged for a section must be cited within it},
  check   = {claim:every-claim-cited}
}

% ── 4. resolver ─────────────────────────────────────────────────────────────
@misc{verifier-named,
  section = {resolver}, from = {claim-bears-check},
  claim   = {a claim's verifier is named type:target},
  check   = {claim:verifier-named}
}
@misc{gate-dispatches,
  section = {resolver}, from = {verifier-named}, join = {, and },
  claim   = {the gate dispatches it through a small registry of check types},
  rests-on = {verifier-named},
  check   = {claim:gate-dispatches}
}
@misc{new-domain-adds,
  section = {resolver}, from = {gate-dispatches}, join = {, so },
  claim   = {supporting a new domain means adding verifiers, not editing the engine},
  rests-on = {gate-dispatches},
  check   = {claim:new-domain-adds}
}
@misc{two-builtins,
  section = {resolver}, from = {gate-dispatches}, join = {. },
  claim   = {two verifiers ship built in},
  rests-on = {file-builtin, cmd-builtin},
  check   = {claim:two-builtins}
}
@misc{file-builtin,
  section = {resolver}, from = {two-builtins}, join = { — },
  claim   = {file, that an artifact exists},
  check   = {claim:file-builtin}
}
@misc{cmd-builtin,
  section = {resolver}, from = {two-builtins}, join = {, and },
  claim   = {cmd, that a script exits zero},
  check   = {claim:cmd-builtin}
}
@misc{cmd-escape,
  section = {resolver}, from = {cmd-builtin, new-domain-adds}, join = {; and },
  claim   = {cmd is the universal escape hatch every other check reduces to},
  rests-on = {cmd-builtin, new-domain-adds},
  check   = {claim:cmd-escape}
}

% ── 5. selfhost ─────────────────────────────────────────────────────────────
@misc{paper-is-paperkit,
  section = {selfhost}, from = {paper-is-projection},
  claim   = {this paper is itself a paperkit project},
  rests-on = {paper-is-projection},
  check   = {claim:paper-is-paperkit}
}
@misc{claims-are-warrants,
  section = {selfhost}, from = {paper-is-paperkit, record-is-bibentry}, join = { — },
  claim   = {its claims are these warrants},
  rests-on = {claim-is-record, record-is-bibentry},
  check   = {claim:claims-are-warrants}
}
@misc{prose-is-projection,
  section = {selfhost}, from = {paper-is-paperkit, prose-projected}, join = {, },
  claim   = {its prose is their projection},
  rests-on = {prose-projected, paper-is-paperkit},
  check   = {claim:prose-is-projection}
}
@misc{gate-is-subject,
  section = {selfhost}, from = {paper-is-paperkit, gate-rejects-drift}, join = {, and },
  claim   = {the gate that accepts it is the very subject it describes},
  rests-on = {gate-rejects-drift, paper-is-paperkit},
  check   = {claim:gate-is-subject}
}
@misc{paperkit-on-paperkit,
  section = {selfhost}, from = {gate-is-subject, gate-rejects-drift}, join = {. },
  claim   = {the verifiers behind this section run paperkit on paperkit --- projecting a fixture, drifting it, and confirming the gate rejects the drift},
  rests-on = {gate-is-subject, gate-rejects-drift, prose-is-projection},
  check   = {claim:paperkit-on-paperkit}
}
@misc{one-green-check,
  section = {selfhost}, from = {paperkit-on-paperkit, gate-is-subject}, join = {, so },
  claim   = {the document's correctness and the tool's are one green check},
  rests-on = {paperkit-on-paperkit, gate-is-subject},
  check   = {claim:one-green-check}
}

% ── projection: the projector's mechanics ───────────────────────────────────
@misc{weave-sentence,
  section = {projection},
  claim   = {within a section the projector weaves the claims into one paragraph rather than a list --- the first clause is capitalized, each carries its own citation tag, and the rest attach inline},
  check   = {claim:weave-sentence}
}
@misc{connector-resolution,
  section = {projection}, from = {weave-sentence}, join = {. },
  claim   = {adjacent clauses are joined by a connector resolved in priority order --- an explicit join wins, else the typed move supplies its default connector, else a legacy glue},
  check   = {claim:connector-resolution}
}
@misc{emit-placement,
  section = {projection}, from = {connector-resolution}, join = {. },
  claim   = {a warrant that names an emit asset is placed verbatim rather than woven --- fenced by the language its extension implies, or rendered as a markdown image when the asset is one},
  check   = {claim:emit-placement}
}
@misc{config-flags,
  section = {projection}, from = {emit-placement}, join = {. },
  claim   = {projection structure is configured, not hard-coded --- the numbered flag toggles section numbers and the references flag toggles the bibliography heading},
  check   = {claim:config-flags}
}
@misc{latex-clean,
  section = {projection}, from = {config-flags}, join = {, and },
  claim   = {claim text is normalized on the way out --- a triple dash becomes an em dash, an inter-word double dash an en dash, LaTeX escapes resolve, braces strip, and a trailing period drops},
  check   = {claim:latex-clean}
}

% ── 7. conclusion ───────────────────────────────────────────────────────────
@misc{closes-gap,
  section = {conclusion}, from = {fail-omits, one-green-check},
  claim   = {by making every claim a verifier and the document their projection, paperkit closes the gap between what a paper says and what has been checked},
  rests-on = {fail-omits, one-green-check, paper-is-projection},
  check   = {claim:closes-gap}
}
@misc{unverified-cant-ship,
  section = {conclusion}, from = {closes-gap, fail-omits}, join = {: },
  claim   = {an unverified sentence cannot ship},
  rests-on = {fail-omits, closes-gap},
  check   = {claim:unverified-cant-ship}
}
@misc{not-project,
  section = {conclusion}, from = {unverified-cant-ship, prose-projected}, join = {, },
  claim   = {because it does not project},
  rests-on = {prose-projected, fail-omits},
  check   = {claim:not-project}
}
