% ── implications: what follows, and the honest limits ────────────────────────
@misc{fresh-by-construction,
  section = {implications},
  claim   = {because the document IS the projection, regenerating it is idempotent and any hand-edit is rejected --- the prose cannot drift from its claims, so what you read is always what was checked},
  check   = {claim:fresh-by-construction}
}
@misc{adequacy-gap,
  section = {implications}, from = {fresh-by-construction}, join = {. },
  claim   = {but a passing check only proves a sentence NAMED a verifier, not that the verifier ENTAILS the claim --- a false sentence with a behavioral yet irrelevant check still passes the gate, so verification here is adequacy, not proof of meaning},
  check   = {claim:adequacy-gap}
}
@misc{crash-sensitive-limit,
  section = {implications}, from = {adequacy-gap}, join = {. },
  claim   = {Δ flags this gap without yet closing it: a check can grade behavioral while sensitive only to inputs other than the document's content, and content-sensitivity marks the difference --- so behavioral is necessary but not sufficient for relevance},
  check   = {claim:crash-sensitive-limit}
}
@misc{trust-boundary,
  section = {implications}, from = {crash-sensitive-limit}, join = {. },
  claim   = {a check is arbitrary code --- cmd is the universal escape hatch every check reduces to --- so gating a document EXECUTES its checks: the warrant set is trusted code, like a makefile, and verifying an untrusted document would be running it},
  check   = {claim:trust-boundary}
}
@misc{env-sanitized,
  section = {implications}, from = {trust-boundary}, join = {, so },
  claim   = {a check runs in a controlled, default-deny environment after sshd's defence against injection --- no inherited LD_PRELOAD, IFS, or BASH_ENV --- so a verdict cannot be injected through the caller's environment, though which tools the PATH resolves remains the host's, leaving reproducibility resting on the host toolchain},
  check   = {claim:env-sanitized}
}
@misc{path-surface,
  section = {implications}, from = {env-sanitized}, join = {. },
  claim   = {That residual is a trust surface, not only a reproducibility one: a check runs through a shell that resolves tools by name, so paperkit drops PATH's relative and empty entries --- the ones that would resolve to the very project directory being gated --- closing the shadow where a document plants a tool beside itself; which absolute directory resolves a tool it keeps, the host's own trust, the same as the toolchain's},
  rests-on = {env-sanitized},
  check   = {claim:path-surface}
}
@misc{grounding-reflected,
  section = {implications}, from = {path-surface}, rests-on = {crash-sensitive-limit}, join = {. },
  link    = {grounded by the relevance gap it narrows (crash-sensitive-limit), stated several claims earlier --- a grounding link counter to prose order},
  claim   = {definition resolution turns each claim's sensitivity into a distinct engine-capability fingerprint, and the coherence grade checks declared grounding against it --- a rests-on edge whose fingerprint is disjoint from its premise's is grounding the measurement cannot see, narrowing the relevance gap by measurement rather than leaving it asserted},
  check   = {claim:grounding-reflected}
}
@misc{forward-direction,
  section = {implications}, from = {grounding-reflected}, join = {. },
  claim   = {the structure residual closes by PROJECTION rather than collapse --- a grounding edge that runs beyond prose adjacency now renders as a transitively-reduced cross-reference, making the grounding DAG visible in the prose and not only in the metadata; its richer materializations, an expounding clause or a figure beyond the bare citation, are the open rhetorical work},
  check   = {claim:forward-direction}
}

