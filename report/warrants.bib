% warrants.bib — the verification REPORT's claims.  Each figure is a markdown table
% RENDERED from machine-readable pipeline data (discriminate --json + gate exit
% codes), not scraped from human output.  The tables are emitted assets, kept
% fresh-by-construction (check = fresh:all, i.e. report/gen.py --check, which
% re-derives every figure and fails if the committed copy has drifted).  Refresh
% with `python3 report/gen.py`.

% ── status ───────────────────────────────────────────────────────────────────
@misc{rpt-status,
  section = {status},
  claim   = {every document the local CI gates passes the gate with zero postulates},
  check   = {cmd:for d in ../paper .. ../boundaries; do python3 ../paperkit/gate.py --safe "$d" >/dev/null 2>&1 || exit 1; done}
}
@misc{rpt-status-out,
  section = {status}, from = {rpt-status}, join = { — },
  claim   = {the verdict per document, each project discovered, not hand-listed},
  emit    = {assets/gate.md},
  check   = {fresh:all}
}

% ── adequacy ─────────────────────────────────────────────────────────────────
@misc{rpt-delta,
  section = {adequacy},
  claim   = {Δ grades each cited claim's check by whether it can actually fail},
  check   = {fresh:all}
}
@misc{rpt-delta-out,
  section = {adequacy}, from = {rpt-delta}, join = { — },
  claim   = {the grade of every cited claim in every document, with why this grade and why not a higher or lower one},
  emit    = {assets/delta.md},
  check   = {fresh:all}
}

% ── proof ────────────────────────────────────────────────────────────────────
@misc{rpt-proof,
  section = {proof},
  claim   = {in every document, every cited claim carries a distinct witness, so --without-K passes (no claim is grounded only by a check it shares with another)},
  check   = {fresh:all}
}
@misc{rpt-proof-out,
  section = {proof}, from = {rpt-proof}, join = { — },
  claim   = {as the proof-relevance check reports},
  emit    = {assets/without-k.md},
  check   = {fresh:all}
}

% ── dag ──────────────────────────────────────────────────────────────────────
@misc{rpt-dag,
  section = {dag},
  claim   = {walking the paper's GROUNDING DAG (rests-on, distinct from prose order; the paper is the one document with grounding edges) from foundational atoms to the theses they support, each claim's adequacy grade plots against its grounding depth},
  check   = {fresh:all}
}
@misc{rpt-dag-fig,
  section = {dag}, from = {rpt-dag}, join = { — },
  claim   = {the foundational atoms on the left, the theses they ground on the right, the effective grade on the vertical axis},
  emit    = {assets/dag.svg},
  check   = {fresh:all}
}
@misc{rpt-clamp,
  section = {dag}, from = {rpt-dag-fig}, join = {. },
  claim   = {a claim is no better grounded than its weakest premise, so each node sits at its effective (clamped) grade, with a ghost rising to its self-check grade wherever premises drag it down},
  check   = {fig:shows-clamp}
}
@misc{rpt-terminal,
  section = {dag}, from = {rpt-clamp}, join = {, and },
  claim   = {the terminal theses --- the claims nothing else rests on, the document's payload --- are ringed},
  check   = {fig:shows-terminal}
}
@misc{rpt-fig-data,
  section = {dag}, from = {rpt-dag-fig}, join = {. },
  claim   = {the figure is rendered from the pipeline data and gated fresh, never placed by hand},
  check   = {fresh:dag.svg}
}
@misc{rpt-fig-palette,
  section = {dag}, from = {rpt-fig-data}, join = {, and is mechanically accessible: },
  claim   = {its colours are the Okabe-Ito colour-blind-safe palette},
  check   = {fig:okabe-ito}
}
@misc{rpt-fig-contrast,
  section = {dag}, from = {rpt-fig-palette}, join = {, },
  claim   = {all its text is dark on a light ground},
  check   = {fig:dark-on-light}
}
@misc{rpt-fig-svg,
  section = {dag}, from = {rpt-fig-contrast}, join = {, and },
  claim   = {it is well-formed vector SVG},
  check   = {fig:well-formed}
}
