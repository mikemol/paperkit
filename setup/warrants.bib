% warrants.bib — the claim-DAG for "Graceful Under Pressure".
%
% Every `check` reads the SHIPPED dataset: ref:<fact> = setup/probe.py <fact>
% --from reference.json, a pure interpretation of interned /proc + /sys readings.
% Because the dataset is a real file in the project, Δ can corrupt it and flip
% each verdict — the claims are non-vacuous (behavioral), not live-kernel reads
% that no mutation can falsify.  `from` carries prose order; `rests-on` is the
% grounding DAG.  Regenerate the dataset with `python3 probe.py --capture`.

% ── machine ──────────────────────────────────────────────────────────────────
@misc{mach-cores,
  section = {machine},
  claim   = {This machine exposes ten logical cores},
  check   = {ref:cores10}
}
@misc{mach-numa,
  section = {machine}, from = {mach-cores}, join = {, and },
  claim   = {all ten share a single NUMA node, so memory is uniform and a worker may land on any core without a cross-node penalty},
  rests-on = {mach-cores},
  check   = {ref:numa1}
}
@misc{mach-hybrid,
  section = {machine}, from = {mach-numa}, join = {. },
  claim   = {The ten are not uniform: six are performance cores and four are efficiency cores, an Intel 12th-generation hybrid part},
  rests-on = {mach-cores},
  check   = {ref:hybrid}
}

% ── swap ─────────────────────────────────────────────────────────────────────
@misc{swap-zram,
  section = {swap},
  claim   = {Swap is served first from a block device that lives in RAM and compresses every page it stores},
  check   = {ref:zram-primary}
}
@misc{swap-zstd,
  section = {swap}, from = {swap-zram}, join = {, using the },
  claim   = {zstd compressor, which favours ratio over raw speed},
  rests-on = {swap-zram},
  check   = {ref:zram-zstd}
}
@misc{swap-inram,
  section = {swap}, from = {swap-zstd}, join = {. },
  claim   = {That device is RAM-backed, not a disk partition},
  rests-on = {swap-zram},
  check   = {ref:zram-in-ram}
}
@misc{swap-size,
  section = {swap}, from = {swap-inram}, join = {, and it is },
  claim   = {sized to roughly sixty percent of total memory, generous headroom for the compressed tier},
  rests-on = {swap-inram},
  check   = {ref:zram-size}
}
@misc{swap-nvme,
  section = {swap}, from = {swap-size}, join = {. },
  claim   = {Behind it, a swapfile on a non-rotational NVMe disk catches the overflow at a lower priority},
  check   = {ref:nvme-overflow}
}
@misc{swap-tier,
  section = {swap}, from = {swap-nvme}, join = {. },
  claim   = {Because the in-RAM device outranks the swapfile, the kernel fills the fast compressed tier completely before it writes a single page to disk},
  rests-on = {swap-zram, swap-nvme},
  check   = {ref:tiered}
}
@misc{swap-swappy,
  section = {swap}, from = {swap-tier}, join = {. },
  claim   = {And the kernel is tuned to reach for that tier early --- swappiness sits well above its timid default},
  rests-on = {swap-tier},
  check   = {ref:swappiness}
}
@misc{swap-zswap,
  section = {swap}, from = {swap-swappy}, join = {. },
  claim   = {There is a second compression layer, too: zswap is enabled, a write-back cache that compresses pages on their way to the disk tier so most never arrive},
  check   = {ref:zswap-enabled}
}
@misc{swap-zswap-lz4,
  section = {swap}, from = {swap-zswap}, join = {. },
  claim   = {It compresses with lz4 --- speed over ratio, the opposite choice from the device's zstd, and the right one for a cache on the hot write-back path},
  rests-on = {swap-zswap},
  check   = {ref:zswap-lz4}
}
@misc{swap-zswap-bounded,
  section = {swap}, from = {swap-zswap-lz4}, join = {. },
  claim   = {And it is itself bounded by construction: its pool may consume no more than a fifth of RAM},
  rests-on = {swap-zswap},
  check   = {ref:zswap-bounded}
}
@misc{swap-zswap-shrinker,
  section = {swap}, from = {swap-zswap-bounded}, join = {, },
  claim   = {beyond which a shrinker writes the coldest pages through to disk --- so the cache copes with sustained pressure instead of simply filling up},
  rests-on = {swap-zswap-bounded},
  check   = {ref:zswap-shrinker}
}

% ── grace ────────────────────────────────────────────────────────────────────
@misc{grace-dedup,
  section = {grace},
  claim   = {A fan-out workload spawns many near-identical processes, and their duplicate pages --- shared interpreter, shared imports --- are exactly what a compressor collapses},
  rests-on = {swap-zstd},
  check   = {ref:compressor}
}
@misc{grace-cheap,
  section = {grace}, from = {grace-dedup}, join = {. },
  claim   = {So memory oversubscription that would thrash a single-tier machine instead stays cheap here: it is paid in CPU cycles to compress, not in milliseconds to seek},
  rests-on = {swap-tier, grace-dedup},
  check   = {ref:psi-io-low}
}
@misc{grace-cpu,
  section = {grace}, from = {grace-cheap}, join = {. },
  claim   = {The overload converts into useful work --- the cores stay saturated rather than blocking on disk},
  rests-on = {grace-cheap, mach-cores},
  check   = {ref:psi-readable}
}

% ── witness ──────────────────────────────────────────────────────────────────
% These rest on loadtest.json — a memory-oversubscription experiment run BOUNDED
% BY CONSTRUCTION (experiment.py, inside a systemd cgroup scope).  The facts
% depend on the heavy load having run, so the experiment is part of the build.
@misc{wit-oversub,
  section = {witness},
  claim   = {To watch this happen on demand, experiment.py allocates twice its memory cap across a dozen worker processes},
  rests-on = {grace-cheap},
  check   = {load:load-oversubscribed}
}
@misc{wit-bounded,
  section = {witness}, from = {wit-oversub}, join = {. },
  claim   = {It needs no restraint to be safe, because it is bounded by construction: it runs inside a systemd cgroup scope with a hard memory cap, and under that two-fold oversubscription its resident set never crossed the cap},
  rests-on = {wit-oversub},
  check   = {load:load-bounded}
}
@misc{wit-spilled,
  section = {witness}, from = {wit-bounded}, join = {. },
  claim   = {The overflow was not killed but spilled to swap, more than a gigabyte of it},
  rests-on = {swap-tier},
  check   = {load:load-swap-spilled}
}
@misc{wit-ioquiet,
  section = {witness}, from = {wit-spilled}, join = {, and here is the point: },
  claim   = {the disk never blocked --- the cgroup's IO stall stayed at three thousandths of a percent, because the spill went into compressed RAM, not onto a platter},
  rests-on = {swap-inram},
  check   = {load:load-io-quiet}
}
@misc{wit-membound,
  section = {witness}, from = {wit-ioquiet}, join = {. },
  claim   = {The cost was real --- under a threefold oversubscription the workload stalled over half the time --- but it fell on memory and CPU, not the disk: the IO stall was a rounding error beside it. The system stayed up by THROTTLING a greedy workload, not by thrashing a platter or invoking the killer},
  rests-on = {grace-dedup},
  check   = {load:load-not-io-bound}
}
@misc{wit-compressed,
  section = {witness}, from = {wit-membound}, join = {. },
  claim   = {And the compressed tier earned its keep, holding the spill at about three and a half to one},
  rests-on = {swap-zstd},
  check   = {load:load-compressed}
}

% ── provenance ───────────────────────────────────────────────────────────────
@misc{prov-source,
  section = {provenance},
  claim   = {None of these numbers were retyped from memory: probe.py's pump() interned them from the live kernel, and the dataset records its own sources --- every one a path under /proc or /sys},
  check   = {ref:env-bound}
}
@misc{prov-fresh,
  section = {provenance}, from = {prov-source}, join = {. },
  claim   = {And the shipped dataset is certified against this very box: a fresh capture's structural readings still match it, so the snapshot genuinely ran here --- re-gate on other hardware and the body still verifies from the data while this provenance check, alone, fails. The claims travel; the proof that they are mine stays home},
  rests-on = {prov-source},
  check   = {fresh:reference.json}
}
