% warrants.bib — the claims of paperkit's front-door doc.  This README is itself
% a paperkit projection of THIS file (root paper.toml: out = README.md).  Every
% example is a CITED claim that also emits its on-disk asset (emit = …): the prose
% introduces and cites it [@key], the block renders below it.  An emit with no
% claim would be an UNCITED placement — a postulate — so there are none here.

% ── pitch ────────────────────────────────────────────────────────────────────
@misc{rm-pitch,
  section = {pitch},
  claim   = {paperkit treats a document as the projection of a verified claim-DAG: you write claims, not prose},
  check   = {file:paperkit/project.py}
}
@misc{rm-verifier,
  section = {pitch}, from = {rm-pitch}, join = {, and },
  claim   = {each claim carries a machine-checkable verifier},
  check   = {file:paperkit/gate.py}
}
@misc{rm-noship,
  section = {pitch}, from = {rm-verifier}, join = {; },
  claim   = {an unverified sentence does not project, so the document cannot overclaim},
  check   = {file:paperkit/gate.py}
}
@misc{rm-selfhost,
  section = {pitch}, from = {rm-noship}, join = {. },
  claim   = {this README is itself such a projection --- its claims are the root warrant set, and its examples are gated assets},
  check   = {file:warrants.bib}
}

% ── model ────────────────────────────────────────────────────────────────────
@misc{rm-model,
  section = {model},
  claim   = {a claim is one bibliography entry --- a statement, the rubric section it belongs to, the claims it depends on (which set prose order and connective glue), and its check},
  check   = {file:paperkit/project.py}
}
@misc{rm-model-eg,
  section = {model}, from = {rm-model}, join = {. },
  claim   = {one entry reads like this},
  emit    = {assets/claim.bib},
  check   = {cmd:grep -q check assets/claim.bib}
}

